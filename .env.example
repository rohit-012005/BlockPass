# Public RPC and network
NEXT_PUBLIC_STELLAR_RPC_URL=https://soroban-testnet.stellar.org
NEXT_PUBLIC_STELLAR_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"
NEXT_PUBLIC_STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
NEXT_PUBLIC_STELLAR_EXPLORER_URL=https://stellar.expert/explorer/testnet
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Deployed contract id (filled in by scripts/deploy-contract.mjs)
NEXT_PUBLIC_BLOCKPASS_CONTRACT_ID=

# Server-only secret used to sign QR check-in tokens.
# Generate with: openssl rand -hex 32
CHECKIN_SIGNING_SECRET=

# Optional: where deployed wasm lives (default public/contracts/blockpass_contract.wasm)
BLOCKPASS_WASM_PATH=

# Deployment (server-side only, never expose)
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"
STELLAR_DEPLOYER_SECRET=
