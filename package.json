{
  "name": "blockpass",
  "version": "0.1.0",
  "private": true,
  "description": "BlockPass — collect ticket money for a small event on Stellar with automatic refunds on cancel.",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "test": "node --test tests/*.test.mjs",
    "contract:check": "cargo check --manifest-path blockpass_contract/Cargo.toml",
    "contract:test": "cargo test --manifest-path blockpass_contract/Cargo.toml",
    "contract:build": "cargo build --manifest-path blockpass_contract/Cargo.toml --target wasm32v1-none --release",
    "contract:fmt": "cargo fmt --manifest-path blockpass_contract/Cargo.toml --all",
    "wasm:sync": "node scripts/sync-wasm.mjs",
    "contract:deploy": "node scripts/deploy-contract.mjs",
    "ci": "npm run lint && npm run typecheck && npm run contract:check && npm run contract:test"
  },
  "dependencies": {
    "@creit.tech/stellar-wallets-kit": "^1.9.5",
    "@stellar/stellar-sdk": "^15.0.1",
    "framer-motion": "^12.42.2",
    "next": "^16.2.10",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.2",
    "@types/node": "^22.10.7",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "autoprefixer": "^10.5.2",
    "eslint": "^9.18.0",
    "eslint-config-next": "^16.2.10",
    "postcss": "^8.5.16",
    "prettier": "^3.4.2",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.7.3"
  }
}
